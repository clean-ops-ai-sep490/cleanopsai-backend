{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "MessageBroker": {
    "Host": "",
    "Username": "",
    "Password": ""
  },
  "ScoringService": {
    "BaseUrl": "http://localhost:8000",
    "EvaluateBatchPath": "/evaluate-batch",
    "EvaluateUrlVisualizeLinkPath": "/evaluate-url-visualize-link",
    "VisualizationImagePath": "/visualizations",
    "TimeoutSeconds": 120
  },
  "ScoringRetrain": {
    "WeeklyJobEnabled": false,
    "WeeklyCronExpression": "0 0 2 ? * SUN *",
    "TimeZoneId": "SE Asia Standard Time",
    "LookbackDays": 7,
    "MinReviewedSamples": 25,
    "MaxSamplesPerBatch": 500,
    "TrainerCommand": "",
    "TrainerWorkingDirectory": "",
    "TrainerTimeoutSeconds": 7200,
    "RemoteTrainerEnabled": false,
    "RemoteTrainerBaseUrl": "http://localhost:8000",
    "RemoteTrainerApiKey": "",
    "RemoteTrainerTimeoutSeconds": 7200,
    "RemoteTrainerPollIntervalSeconds": 5,
    "RemoteTrainerCreatePath": "/retrain/jobs",
    "RemoteTrainerStatusPathTemplate": "/retrain/jobs/{jobId}",
    "ObjectStorageEnabled": true,
    "ObjectStorageConnectionString": "DefaultEndpointsProtocol=https;AccountName=<storage_account>;AccountKey=<account_key>;EndpointSuffix=core.windows.net",
    "ObjectStorageModelsContainer": "models",
    "ObjectStorageRetrainContainer": "retrain",
    "ReviewedSnapshotsEnabled": true,
    "ReviewedSamplesContainer": "retrain-samples",
    "ReviewedSamplesPrefix": "scoring/retrain-samples",
    "ReviewedBridgeEnabled": false,
    "ReviewedBridgeCommand": "",
    "UseExternalCandidateForRetrain": false,
    "CandidateYoloModelFile": "outputs/retrain/candidate/yolo_best.pt",
    "CandidateUnetModelFile": "outputs/retrain/candidate/unet_best.pth",
    "CandidateMetricsFile": "outputs/retrain/candidate_metrics.json",
    "ActiveYoloObjectKey": "scoring/active/yolo/model.pt",
    "ActiveUnetObjectKey": "scoring/active/unet/model.pth",
    "ActiveMetricsObjectKey": "scoring/active/metrics/metrics.json",
    "CandidatePrefix": "scoring/candidates",
    "ExternalCandidatePrefix": "scoring/external/latest",
    "ManifestPrefix": "scoring/manifests",
    "ArchivePrefix": "scoring/archive",
    "YoloMapMetricKey": "yolo.map",
    "UnetMiouMetricKey": "unet.miou",
    "MinimumYoloMapImprovement": 0.0,
    "MinimumUnetMiouImprovement": 0.0,
    "PromoteWhenNoBaseline": false,
    "PromotionCommand": "",
    "RestartServiceCommand": ""
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  }
}
