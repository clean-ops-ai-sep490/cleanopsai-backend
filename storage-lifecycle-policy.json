{
  "rules": [
    {
      "enabled": true,
      "name": "cleanup-retrain-working-artifacts",
      "type": "Lifecycle",
      "definition": {
        "actions": {
          "baseBlob": {
            "delete": {
              "daysAfterModificationGreaterThan": 30
            }
          }
        },
        "filters": {
          "blobTypes": ["blockBlob"],
          "prefixMatch": [
            "retrain/candidates/",
            "retrain/manifests/",
            "retrain/external/"
          ]
        }
      }
    },
    {
      "enabled": true,
      "name": "cleanup-retrain-archive",
      "type": "Lifecycle",
      "definition": {
        "actions": {
          "baseBlob": {
            "delete": {
              "daysAfterModificationGreaterThan": 180
            }
          }
        },
        "filters": {
          "blobTypes": ["blockBlob"],
          "prefixMatch": [
            "retrain/archive/"
          ]
        }
      }
    }
  ]
}
